[sub_resource type="GDScript" id="GDScript_o6xl0"]
resource_name = "hints"
script/source = "extends CanvasLayer

@onready var base = $Control/CenterContainer/Hint

var hints : Dictionary = {}

func clear_hints():
	for hint in hints.values():
		hint.queue_free()
	hints = {}

func center_hint_raw(r):
	var key = r[0]
	var keycode = r[1]
	var label = r[2]
	center_hint(key, keycode, label)

func hint_raw(r):
	var key = r[0]
	var keycode = r[1]
	var label = r[2]
	hint(key, keycode, label)

func center_hint(key, keycode, label):
	_add_hint($Control/CenterContainer/VBoxContainer, true, key, keycode, label)

func center_top_hint(key, keycode, label):
	_add_hint($Control/CenterContainer/CenterTop, true, key, keycode, label)

func hint(key, keycode, label):
	_add_hint($Control/MarginContainer/VBoxContainer, false, key, keycode, label)

func _add_hint(node, centered, key, keycode, label):
	var h = hints.get(key)
	if h:
		h.set_hint(keycode, label)
		return
	var hint : HBoxContainer = base.duplicate()
	if centered: hint.alignment = BoxContainer.ALIGNMENT_CENTER
	node.add_child(hint)
	hint.set_hint(keycode, label)
	hints[key] = hint
	hint.show()
	

func rm_hint(key):
	var h = hints.get(key)
	if h == null: return
	h.queue_free()
	hints.erase(key)
"

[sub_resource type="Theme" id="Theme_o6xl0"]
