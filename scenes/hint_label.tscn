[sub_resource type="GDScript" id="GDScript_nu38a"]
resource_name = "hint_label"
script/source = "extends StaticBody3D

@export var hint1 = \"USE\"
@export var hint2 = \"USE\"
@export var hint3 = \"USE\"
@export var hint4 = \"USE\"
@export var hover = \"USE\"
@export var hover_key = \"KEY\"

func _ready():
	$Label3D.text = hint1 + '\\n' + hint2 + '\\n' + hint3 + '\\n' + hint4

func hint():
	return [
		\"label_hint\",
		hover_key,
		hover
	]
"

