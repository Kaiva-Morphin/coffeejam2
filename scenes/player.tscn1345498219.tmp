[sub_resource type="GDScript" id="GDScript_85g3d"]
resource_name = "rigid_player"
script/source = "extends RigidBody3D

@export var SPEED: float = 10.0
@export var LOSS_SPEED: float = 50.0
@export var GRAVITY_SCALE: float = 20.0
@export var MOUSE_SENSITIVITY: float = 0.002

@export var TILT_LOWER_LIMIT := deg_to_rad(-70.0)
@export var TILT_UPPER_LIMIT := deg_to_rad(80.0)

@export var CAMERA_CONTROLLER: Camera3D
@export var PICKUP_RAYCAST: RayCast3D
@onready var HINTS = $\"../Hints\"

var PICKED_PIN : PinJoint3D
var PICKED_STATIC : StaticBody3D

var _mouse_input := false
var _rotation_input := 0.0
var _tilt_input := 0.0
var _mouse_rotation := Vector2.ZERO

var picked_item: RigidBody3D = null
var picked_joint: bool = false
var held_distance = 10.0
@export var dbg: Node3D
@export var ANIMATION: AnimationTree



enum PLAYERSTATE {
	Controlled,
	CampFire,
	CoffeeMachine,
	Sitting
}
var current_state = PLAYERSTATE.Controlled

func _ready() -> void:
	Input.mouse_mode = Input.MOUSE_MODE_CAPTURED
	$stick_in.hide()

func _unhandled_input(event: InputEvent) -> void:
	if event.is_action_pressed(\"ui_cancel\"):
		_mouse_input = !_mouse_input
		Input.mouse_mode = Input.MOUSE_MODE_VISIBLE if _mouse_input else Input.MOUSE_MODE_CAPTURED
	if current_state == PLAYERSTATE.CampFire:
		stick_unhandled_input(event)
	if current_state != PLAYERSTATE.Controlled: return
	if event is InputEventMouseMotion and Input.mouse_mode == Input.MOUSE_MODE_CAPTURED:
		_rotation_input -= event.relative.x * MOUSE_SENSITIVITY
		_tilt_input -= event.relative.y * MOUSE_SENSITIVITY

func _process(_dt: float) -> void:
	match current_state:
		PLAYERSTATE.Controlled:
			control_tick(_dt)
		PLAYERSTATE.Sitting:
			sit_tick(_dt)
		PLAYERSTATE.CampFire:
			campfire_tick(_dt)
			if Input.is_action_just_pressed(\"back\"):
				if !zefir_throwable():
					current_state = PLAYERSTATE.Controlled
					campfire_cleanup()
				else:
					zefir_on_stick = false
					#var z = zefirkla_shape.duplicate()
					#z.global_transform = zefirkla_shape.global_transform
					#var shape
					#var rb = RigidBody3D.new()
					#rb.add_child(shape)
					#get_tree().root.add_child(rb)
					#rb.global_transform = zefirkla_shape.global_transform
					zefirkla.hide()
		PLAYERSTATE.CoffeeMachine:
			pass
		





func _physics_process(delta: float) -> void:
	if current_state == PLAYERSTATE.CampFire: campfire_physics_tick(delta)

func _integrate_forces(state: PhysicsDirectBodyState3D) -> void:
	integrate_control(state)

func integrate_control(state: PhysicsDirectBodyState3D):
	_mouse_rotation.x = clamp(_mouse_rotation.x + _tilt_input, TILT_LOWER_LIMIT, TILT_UPPER_LIMIT)
	_mouse_rotation.y += _rotation_input
	rotation.y = _mouse_rotation.y
	CAMERA_CONTROLLER.rotation.x = _mouse_rotation.x
	CAMERA_CONTROLLER.rotation.z = 0.0
	_rotation_input = 0.0
	_tilt_input = 0.0
	var input_dir := Vector2.ZERO
	if current_state == PLAYERSTATE.Controlled:
		input_dir = Vector2(
			Input.get_axis(\"left\", \"right\"),
			Input.get_axis(\"forward\", \"backward\")
		)
	var direction := Vector3.ZERO
	if input_dir != Vector2.ZERO:
		direction = (global_transform.basis * Vector3(input_dir.x, 0, input_dir.y)).normalized()
		ANIMATION.set(\"parameters/walk/blend_amount\", 1.0)
		ANIMATION.set(\"parameters/r_walk/blend_amount\", 1.0)
		ANIMATION.set(\"parameters/l_walk/blend_amount\", 1.0)
	else:
		ANIMATION.set(\"parameters/walk/blend_amount\", 0.0)
		ANIMATION.set(\"parameters/r_walk/blend_amount\", 0.0)
		ANIMATION.set(\"parameters/l_walk/blend_amount\", 0.0)
	var target_velocity := direction * SPEED
	var current_velocity := state.get_linear_velocity()
	var new_velocity := current_velocity.move_toward(target_velocity, LOSS_SPEED * state.get_step())
	new_velocity.y = current_velocity.y
	state.set_linear_velocity(new_velocity)
	apply_central_impulse(Vector3.DOWN * GRAVITY_SCALE * mass * state.get_step())
	if picked_item:
		if picked_joint:
			var target_pos = PICKUP_RAYCAST.global_position - PICKUP_RAYCAST.global_transform.basis.z * held_distance
			var dir = target_pos - picked_item.global_position
			picked_item.linear_velocity = linear_velocity + dir * 10.0
		else:
			PICKED_STATIC.global_position = PICKUP_RAYCAST.global_position - PICKUP_RAYCAST.global_transform.basis.z * held_distance
	$Camera/CanvasLayer/AspectRatioContainer/SubViewportContainer/SubViewport/Camera.global_transform = $Camera.global_transform
	$Camera/CanvasLayer/AspectRatioContainer/SubViewportContainer/SubViewport.size = get_window().size


### ----- FREE -----

func control_tick(_dt: float):
	if Input.is_action_just_released(\"lmb\") and picked_item:
		picked_item.sleeping = false
		if !picked_joint:
			picked_item.center_of_mass_mode = RigidBody3D.CENTER_OF_MASS_MODE_AUTO
			PICKED_PIN.queue_free()
			PICKED_PIN = null
			PICKED_STATIC.queue_free()
			PICKED_STATIC = null
		picked_item = null
	var body = PICKUP_RAYCAST.get_collider()
	if Input.is_action_just_pressed(\"lmb\"):
		if body and body is RigidBody3D and picked_item == null and body.is_in_group(\"pickable\"):
			picked_item = body
			var d = PICKUP_RAYCAST.get_collision_point()
			held_distance = (d - PICKUP_RAYCAST.global_position).length()
			if picked_item.is_in_group(\"pickable_joint\"):
				picked_joint = true
			else:
				var p := PinJoint3D.new()
				var s := StaticBody3D.new()
				get_tree().root.add_child(s)
				get_tree().root.add_child(p)
				p.set(\"params/bias\", 0.1)
				p.global_position = d
				s.global_position = d
				p.node_b = s.get_path()
				p.node_a = body.get_path()
				p.solver_priority = 2
				PICKED_PIN = p
				PICKED_STATIC = s
				picked_joint = false
	
	if body and body.is_in_group(\"pickable\") and !picked_item:
		HINTS.center_hint(\"pick\", \"ЛКМ\", \"Тянуть\")
	else:
		HINTS.rm_hint(\"pick\")
	
	if body and body.is_in_group(\"heldable\") and !held_item and !picked_item:
		HINTS.center_hint(\"take\", \"E\", \"Взять\")
		if Input.is_action_just_pressed(\"interact\"):
			pick_item(body)
	else:
		HINTS.rm_hint(\"take\")
	
	if held_item:
		HINTS.hint(\"throw\", \"Q\", \"Выбросить\")
		ANIMATION.set(\"parameters/l_pick/blend_amount\", 1.0)
		if Input.is_action_just_pressed(\"back\"):
			throw_item()
	else:
		ANIMATION.set(\"parameters/l_pick/blend_amount\", 0.0)
		HINTS.rm_hint(\"throw\")
	
	if body and body.is_in_group(\"interactable\") and !picked_item:
		if body.is_in_group(\"campfire\"):
			HINTS.center_hint(\"e\", \"E\", \"Жарить маршмелов\")
			if Input.is_action_just_pressed(\"interact\"):
				current_state = PLAYERSTATE.CampFire
				campfire_setup(body.global_position)
		if body.is_in_group(\"coffeemachine\"):
			HINTS.center_hint(\"e\", \"E\", \"Готовить кофе\")
			if Input.is_action_just_pressed(\"interact\"):
				current_state = PLAYERSTATE.CoffeeMachine
				coffeemachine_setup(body.global_position)
		if body.is_in_group(\"log\"):
			HINTS.center_hint(\"e\", \"E\", \"Сесть\")
			if Input.is_action_just_pressed(\"interact\"):
				current_state = PLAYERSTATE.Sitting
				sit_setup(body.global_position)
	else:
		HINTS.rm_hint(\"e\")






### ----- SITTING -----

var sit_target_pos: Vector3
var sit_target_yaw: float
var sit_speed := 5.0
var sit_rot_speed := 6.0

var sit_log_basis: Basis
var sit_local_yaw := 0.0

const SIT_YAW_LIMIT := deg_to_rad(60.0)
const SIT_SOFTNESS := 8.0 # скорость возврата
var sit_base_yaw := 0.0


@onready var default_collision_mask = collision_mask

func sit_setup(log: Node3D):
	freeze = true
	collision_mask = 0
	current_state = PLAYERSTATE.Sitting
	HINTS.hint(\"q\", \"Q\", \"Встать\")

	# позиция — оставляем твою
	sit_target_pos = log.global_position + Vector3(0.0, 1.0, 0.0)

	# сохраняем базис бревна
	sit_log_basis = log.global_transform.basis

	# текущий forward игрока
	var player_forward := -global_transform.basis.z
	player_forward.y = 0.0
	player_forward = player_forward.normalized()

	# переводим forward в локальное пространство бревна
	var local_forward := sit_log_basis.inverse() * player_forward

	# локальный yaw относительно Z бревна
	sit_local_yaw = atan2(local_forward.x, local_forward.z)

	_rotation_input = 0.0
	_tilt_input = 0.0

func sit_tick(dt: float):
	# посадка
	global_position = global_position.lerp(
		sit_target_pos,
		dt * sit_speed
	)

	# свободное вращение
	_mouse_rotation.y += _rotation_input
	_mouse_rotation.x = clamp(
		_mouse_rotation.x + _tilt_input,
		TILT_LOWER_LIMIT,
		TILT_UPPER_LIMIT
	)

	# считаем текущий forward
	var forward := -Basis(Vector3.UP, _mouse_rotation.y).z
	forward.y = 0.0
	forward = forward.normalized()

	# в локальное пространство бревна
	var local_forward := sit_log_basis.inverse() * forward
	var local_yaw := atan2(local_forward.x, local_forward.z)

	# мягкое ограничение
	if abs(local_yaw - sit_local_yaw) > SIT_YAW_LIMIT:
		var target_local_yaw = sit_local_yaw + clamp(
			local_yaw - sit_local_yaw,
			-SIT_YAW_LIMIT,
			SIT_YAW_LIMIT
		)

		# переводим обратно в мировой yaw
		var target_forward := sit_log_basis * Vector3(
			sin(target_local_yaw),
			0.0,
			cos(target_local_yaw)
		)

		var target_yaw := atan2(target_forward.x, target_forward.z)
		_mouse_rotation.y = lerp_angle(
			_mouse_rotation.y,
			target_yaw,
			dt * SIT_SOFTNESS
		)

	rotation.y = _mouse_rotation.y
	CAMERA_CONTROLLER.rotation.x = _mouse_rotation.x

	_rotation_input = 0.0
	_tilt_input = 0.0

	if Input.is_action_just_pressed(\"back\"):
		sit_cleanup()

func sit_cleanup():
	HINTS.rm_hint(\"q\")
	current_state = PLAYERSTATE.Controlled
	freeze = false
	collision_mask = default_collision_mask

### ----- ITEM -----


var held_item : RigidBody3D = null
func pick_item(body: RigidBody3D):
	body.freeze = true
	for hint in body.hints():
		HINTS.hint_raw(hint)
	body.reparent($Held, false)
	body.transform = Transform3D.IDENTITY
	held_item = body

func throw_item():
	held_item.freeze = false
	for hint in held_item.hints():
		var key = hint[0]
		HINTS.rm_hint(key)
	held_item.reparent(get_tree().root, true)
	held_item = null

func use_item():
	pass





### ----- COFFEE -----


func coffeemachine_setup(body):
	pass




### ----- CAMPFIRE -----

var campfire_speed = 4.5
var campfire_rot_speed = 4.5
var campfire_target = Vector3.ZERO
var campfire_rot_target = Vector3.ZERO


func campfire_setup(target):
	zefir_progress = 1.0
	HINTS.hint(\"q\", \"Q\", \"Уйти\")
	HINTS.hint(\"shift\", \"Shift\", \"Вытянуть\")
	HINTS.rm_hint(\"e\")
	campfire_target = target + ((global_position - target) * Vector3(1.0, 0.0, 1.0)).normalized() * 3.0
	campfire_rot_target = target
	$stick_initial.play(\"in\")
	$zefirka.play(\"RESET\")
	$stick.play(\"pull\")
	zefir_on_stick = true

var zefir_progress = 1.0
var zefir_on_stick = true

var stick_rot := Vector2.ZERO
@export var STICK_SENS := 0.003
@export var STICK_PITCH_LIMIT := Vector2(deg_to_rad(-30), deg_to_rad(30))
@export var STICK_YAW_LIMIT   := Vector2(deg_to_rad(-60), deg_to_rad(60))

var stick_push := false
@onready var STICK = $stick_in/zefirka_root/stick
@export var STICK_RETURN_SPEED := 6.0
@onready var zefirkla = $stick_in/zefirka_root/stick/stick/zefirka
func stick_unhandled_input(event):
	if event is InputEventMouseMotion \\
	and Input.mouse_mode == Input.MOUSE_MODE_CAPTURED \\
	and current_state == PLAYERSTATE.CampFire \\
	and stick_push \\
	:
		stick_rot.y -= event.relative.x * STICK_SENS
		stick_rot.x -= event.relative.y * STICK_SENS
		stick_rot.x = clamp(
			stick_rot.x,
			STICK_PITCH_LIMIT.x,
			STICK_PITCH_LIMIT.y
		)
		stick_rot.y = clamp(
			stick_rot.y,
			STICK_YAW_LIMIT.x,
			STICK_YAW_LIMIT.y
		)

func zefir_throwable():
	return zefir_progress < 0.2 and !stick_push and zefir_on_stick

func campfire_tick(dt: float):
	if !zefir_on_stick:
		HINTS.center_hint(\"swap\", \"E\", \"Заменить\")
		if Input.is_action_just_pressed(\"interact\"):
			zefir_on_stick = true
			zefir_progress = 1.0
			$zefirka.play(\"swap\")
	else:
		HINTS.rm_hint(\"swap\")
	if !stick_push:
		if zefir_throwable():
			HINTS.center_hint(\"eat\", \"E\", \"Скушать\")
			HINTS.center_hint(\"throw\", \"Q\", \"Выкинуть\")
			if Input.is_action_just_pressed(\"interact\"):
				zefir_on_stick = false
				zefirkla.hide()
		elif zefir_progress < 0.7 and zefir_on_stick:
			HINTS.center_hint(\"eat\", \"E\", \"Скушать\")
			if Input.is_action_just_pressed(\"interact\"):
				zefir_on_stick = false
				zefirkla.hide()
		else:
			HINTS.rm_hint(\"eat\")
			HINTS.rm_hint(\"throw\")
	else:
		HINTS.rm_hint(\"throw\")
		HINTS.rm_hint(\"eat\")
		
	global_position = global_position.lerp(
		campfire_target,
		dt * campfire_speed
	)
	var dir = (global_position - campfire_rot_target).normalized()
	var target_yaw = atan2(dir.x, dir.z)
	_mouse_rotation.y = lerp_angle(_mouse_rotation.y, target_yaw, dt * campfire_rot_speed)
	rotation.y = _mouse_rotation.y
	var target_pitch = asin(dir.y)
	_mouse_rotation.x = lerp(
		_mouse_rotation.x,
		clamp(target_pitch, TILT_LOWER_LIMIT, TILT_UPPER_LIMIT),
		dt * campfire_rot_speed
	)
	CAMERA_CONTROLLER.rotation.x = _mouse_rotation.x
	var areas = $stick_in/zefirka_root/stick/stick/zefirka/Area3D.get_overlapping_areas()
	for area in areas:
		if area.is_in_group(\"zefir_burn\"):
			zefir_progress = -1.0
		if area.is_in_group(\"zefir_cook\"):
			if zefir_progress > 0.0:
				zefir_progress -= 1.0 * dt
	
	if zefir_progress < 0.0:
		zefirkla.material_override.albedo_color = Color.BLACK
	else:
		var v = zefir_progress
		var c = v * Color.from_rgba8(255, 255, 255, 255) + (1 - v) * Color.from_rgba8(74, 43, 0, 255)
		c.a = 1
		zefirkla.material_override.albedo_color = c
	
	if Input.is_action_just_pressed(\"shift\"):
		stick_push = true
		$stick.play(\"push\")
	
	if Input.is_action_just_released(\"shift\"):
		stick_push = false
		$stick.play(\"pull\")
	
	if stick_push:
		STICK.rotation.z = lerp(
			STICK.rotation.z,
			-stick_rot.y,
			dt * 10.0
		)
		STICK.rotation.y = lerp(
			STICK.rotation.y,
			-stick_rot.x,
			dt * 10.0
		)
	else:
		STICK.rotation.z = lerp(
			STICK.rotation.z,
			0.0,
			dt * STICK_RETURN_SPEED
		)
		STICK.rotation.y = lerp(
			STICK.rotation.y,
			0.0,
			dt * STICK_RETURN_SPEED
		)
		stick_rot = stick_rot.lerp(Vector2.ZERO, dt * STICK_RETURN_SPEED)

func campfire_physics_tick(_dt):
	pass

func campfire_cleanup():
	HINTS.rm_hint(\"q\")
	HINTS.rm_hint(\"shift\")
	$stick_initial.play(\"out\")
	HINTS.rm_hint(\"swap\")
	HINTS.rm_hint(\"throw\")
	HINTS.rm_hint(\"eat\")
"

