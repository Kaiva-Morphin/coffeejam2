[sub_resource type="GDScript" id="GDScript_3yv71"]
resource_name = "snowball"
script/source = "# Snowball.gd
extends Heldable
#class_name Snowball

@export var growth_rate: float = 0.05        # скорость роста
@export var max_scale: float = 5.5          # максимальный размер
@export var min_roll_speed: float = 0.3     # минимальная скорость для роста
@export var ray_length: float = 0.101         # длина рейкаста вниз
var current_size = 0.1
var ground_ray: RayCast3D

var preview
@export var preview_material : StandardMaterial3D

func _ready():
	if preview_material == null:
		preview_material = StandardMaterial3D.new()
		preview_material.albedo_color = Color(0.2, 1, 0.4, 0.4)
		preview_material.transparency = BaseMaterial3D.TRANSPARENCY_ALPHA
	ground_ray = RayCast3D.new()
	ground_ray.collide_with_areas = false
	ground_ray.collide_with_bodies = true
	add_child(ground_ray)
	ground_ray.enabled = true
	$CollisionShape3D.shape = $CollisionShape3D.shape.duplicate(true)
	$MeshInstance3D.mesh = $MeshInstance3D.mesh.duplicate(true)
	
	preview = $MeshInstance3D.duplicate()
	get_tree().root.add_child.call_deferred(preview)
	preview.hide()
	preview.material_override = preview_material


func _physics_process(delta):
	_update_ground_ray()
	var on_ground := ground_ray.is_colliding()
	#print(on_ground)
	
	ray_length = current_size # + 0.05

	# Горизонтальная скорость
	var horizontal_velocity := linear_velocity
	horizontal_velocity.y = 0.0
	var speed := horizontal_velocity.length()
	
	var is_rolling := on_ground and speed > min_roll_speed
	#print(horizontal_velocity)
	if is_rolling:
		var grow = growth_rate * speed * delta
		current_size += grow
		current_size = clamp(current_size, 0.0, max_scale)
		$MeshInstance3D.mesh.radius = current_size
		$MeshInstance3D.mesh.height = current_size * 2
		$CollisionShape3D.shape.radius = current_size
		#current_size += grow
		#scale += Vector3.ONE * current_size
		#scale = scale.clamp(Vector3.ONE, Vector3.ONE * max_scale)


func _update_ground_ray():
	#var down_dir: Vector3 = -global_transform.basis.y.normalized()
	#ground_ray.global_transform.origin = global_transform.origin
	ground_ray.global_rotation = Vector3(0., 0., 0)
	ground_ray.target_position = Vector3.DOWN * ray_length


func tick_ray(point: Vector3, _dir, body, _normal):
	#GLOBAL.dbg.global_position = point
	if body:
		preview.show()
		preview.global_position = point
		#current_size
	else:
		preview.hide()

func cleanup():
	preview.hide()
"

