[sub_resource type="GDScript" id="GDScript_1q667"]
resource_name = "hint_record"
script/source = "extends HBoxContainer

@onready var btn = $Btn
@onready var label = $Label

func set_hint(key, text):
	btn.text = key
	label.text = text
"

